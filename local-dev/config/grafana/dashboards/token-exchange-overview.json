{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "lineWidth": 2 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum(rate(identity_fabric_token_exchange_requests_total[1m])) by (adapter)",
          "legendFormat": "{{adapter}}",
          "exemplar": true
        }
      ]
    },
    {
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum(rate(identity_fabric_token_exchange_requests_total{status=\"error\"}[1m])) / sum(rate(identity_fabric_token_exchange_requests_total[1m]))",
          "legendFormat": "Error Rate",
          "exemplar": true
        }
      ]
    },
    {
      "title": "Request Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum(rate(identity_fabric_token_exchange_request_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p50",
          "exemplar": true
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum(rate(identity_fabric_token_exchange_request_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p95",
          "exemplar": true
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum(rate(identity_fabric_token_exchange_request_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p99",
          "exemplar": true
        }
      ]
    },
    {
      "title": "Adapter Latency Breakdown",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "lineWidth": 2 },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(identity_fabric_token_exchange_adapter_duration_seconds_bucket[1m])) by (le, adapter))",
          "legendFormat": "{{adapter}} p95",
          "exemplar": true
        }
      ]
    },
    {
      "title": "Active In-Flight Requests",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "identity_fabric_token_exchange_active_requests",
          "legendFormat": "Active"
        }
      ]
    },
    {
      "title": "Tokens Issued by Trust Level",
      "type": "piechart",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "pieType": "donut"
      },
      "targets": [
        {
          "expr": "sum(identity_fabric_token_exchange_tokens_issued_total) by (trust_level)",
          "legendFormat": "{{trust_level}}"
        }
      ]
    },
    {
      "title": "Tokens Issued by Auth Method",
      "type": "piechart",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "pieType": "donut"
      },
      "targets": [
        {
          "expr": "sum(identity_fabric_token_exchange_tokens_issued_total) by (auth_method)",
          "legendFormat": "{{auth_method}}"
        }
      ]
    },
    {
      "title": "Mint Latency (p95)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(identity_fabric_token_exchange_mint_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "Mint p95"
        }
      ]
    },
    {
      "title": "Request Rate by Adapter",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "sum(rate(identity_fabric_token_exchange_requests_total[5m])) by (adapter, status)",
          "legendFormat": "{{adapter}} ({{status}})"
        }
      ]
    },
    {
      "title": "Logs (token-exchange)",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 30 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "expr": "{compose_service=\"token-exchange\"} | json | line_format \"{{.msg}}\"",
          "legendFormat": ""
        }
      ]
    },
    {
      "title": "Recent Traces",
      "type": "traces",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "jaeger", "uid": "jaeger" },
      "targets": [
        {
          "queryType": "search",
          "service": "token-exchange",
          "limit": 20
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["identity-fabric", "token-exchange", "observability"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Token Exchange Service",
  "uid": "identity-fabric-token-exchange",
  "version": 2
}
